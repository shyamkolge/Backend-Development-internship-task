# Database Configuration - Supabase
# Option 1: Use Supabase Connection String (Recommended)
# Get from: https://app.supabase.com/project/[project-id]/settings/database
DATABASE_URL=postgresql://postgres:[YOUR_PASSWORD]@[YOUR_HOST]:[YOUR_PORT]/[YOUR_DATABASE]?sslmode=require

# Option 2: Use individual parameters (if not using DATABASE_URL)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=auth_db
# DB_USER=postgres
# DB_PASSWORD=your_password

# Server Configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=your_refresh_token_secret_change_this_in_production
REFRESH_TOKEN_EXPIRES_IN=14d

# Bcrypt Configuration
BCRYPT_ROUNDS=10
